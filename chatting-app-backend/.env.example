PORT=5001
NODE_ENV=development

MONGODB_URI=mongodb://localhost:27017/chatting-app

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Comma-separated allowed frontend origins (CORS + Socket.IO)
CLIENT_URL=http://localhost:3000,http://127.0.0.1:3000

UPLOAD_DIR=uploads

# AWS S3 (required for image uploads)
# AWS_REGION must match the bucket region (backet-for-confaero is us-east-2)

# IAM user needs at least: s3:PutObject, s3:GetObject on arn:aws:s3:::BUCKET/*

# Upstash Redis (optional — app works without it)
# Use the URL only — not the redis-cli command from Upstash
REDIS_URL=rediss://default:gQAAAAAAATcCAAIgcDFkNjkzMTFhZTBkNDE0YWMxYTM4ODQ3ZDM0MTI4Y2MyNg@ultimate-grizzly-79618.upstash.io:6379
REDIS_ENABLED=true

# redis-cli --tls -u redis://default:gQAAAAAAATcCAAIgcDFkNjkzMTFhZTBkNDE0YWMxYTM4ODQ3ZDM0MTI4Y2MyNg@ultimate-grizzly-79618.upstash.io:6379
