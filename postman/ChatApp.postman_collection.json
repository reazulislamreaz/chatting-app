{
  "info": {
    "name": "ChatApp API",
    "description": "Real-time chat application API collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5001/api" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "friendId", "value": "" },
    { "key": "requestId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.token) {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "  pm.collectionVariables.set('userId', res.data.user.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.token) {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "  pm.collectionVariables.set('userId', res.data.user.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Me",
          "request": { "method": "GET", "url": "{{baseUrl}}/auth/me" }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"password123\",\n  \"newPassword\": \"newpassword123\",\n  \"confirmPassword\": \"newpassword123\"\n}"
            },
            "url": "{{baseUrl}}/auth/change-password"
          }
        },
        {
          "name": "Logout",
          "request": { "method": "POST", "url": "{{baseUrl}}/auth/logout" }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Profile",
          "request": { "method": "GET", "url": "{{baseUrl}}/users/profile" }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "name", "value": "John Updated", "type": "text" }]
            },
            "url": "{{baseUrl}}/users/profile"
          }
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users?search=&page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["users"],
              "query": [
                { "key": "search", "value": "" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get User By ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/users/{{friendId}}" }
        }
      ]
    },
    {
      "name": "Friend Requests",
      "item": [
        {
          "name": "Send Request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"receiverId\": \"{{friendId}}\"\n}"
            },
            "url": "{{baseUrl}}/friend-requests"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.id) pm.collectionVariables.set('requestId', res.data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Received Requests",
          "request": { "method": "GET", "url": "{{baseUrl}}/friend-requests/received" }
        },
        {
          "name": "Get Sent Requests",
          "request": { "method": "GET", "url": "{{baseUrl}}/friend-requests/sent" }
        },
        {
          "name": "Get Friends",
          "request": { "method": "GET", "url": "{{baseUrl}}/friend-requests/friends" }
        },
        {
          "name": "Accept Request",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"action\": \"accept\"\n}" },
            "url": "{{baseUrl}}/friend-requests/{{requestId}}/respond"
          }
        },
        {
          "name": "Reject Request",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"action\": \"reject\"\n}" },
            "url": "{{baseUrl}}/friend-requests/{{requestId}}/respond"
          }
        }
      ]
    },
    {
      "name": "Messages",
      "item": [
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"receiverId\": \"{{friendId}}\",\n  \"content\": \"Hello!\"\n}"
            },
            "url": "{{baseUrl}}/messages"
          }
        },
        {
          "name": "Get Conversation",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/messages/{{friendId}}?page=1&limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["messages", "{{friendId}}"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "50" }
              ]
            }
          }
        },
        {
          "name": "Mark Messages Read",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senderId\": \"{{friendId}}\"\n}"
            },
            "url": "{{baseUrl}}/messages/read"
          }
        }
      ]
    },
    {
      "name": "Chats",
      "item": [
        {
          "name": "Get Chat List",
          "request": { "method": "GET", "url": "{{baseUrl}}/chats" }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "http://localhost:5001/health"
          }
        }
      ]
    }
  ]
}
