# REST API via Next.js proxy (recommended — avoids CORS)
NEXT_PUBLIC_API_URL=/api

# Local dev (chatting-app-backend on PORT=8081)
BACKEND_PROXY_URL=http://localhost:8081
NEXT_PUBLIC_SOCKET_URL=http://localhost:8081
NEXT_PUBLIC_UPLOADS_URL=http://localhost:8081

# Production example (use your real chatting-app API host, NOT a different app on :8080)
# BACKEND_PROXY_URL=https://your-chat-api.example.com
# NEXT_PUBLIC_SOCKET_URL=https://your-chat-api.example.com
# NEXT_PUBLIC_UPLOADS_URL=https://your-chat-api.example.com
